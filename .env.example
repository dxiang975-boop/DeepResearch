# DeepResearch 项目环境变量配置
# 说明：.env.example 是示例模板；.env 是本机真实配置，通常不要提交到 Git。

# DashScope/通义千问 API Key，后端调用 Qwen 模型和 Embedding 必填。
DASHSCOPE_API_KEY=

# 主模型名称，例如 qwen-plus、qwen-turbo。
MODEL=qwen-plus

# Bocha Web Search API Key，用于网络检索；不填则 web_search 节点拿不到网页证据。
BOCHA_API_KEY=

# 默认会话 ID；前端请求也可以传 thread_id 覆盖。
THREAD_ID=default

# 默认用户 ID，用于区分不同用户的记忆。
USER_ID=default_user

# 默认租户 ID，用于多租户隔离。
TENANT_ID=default_tenant

# 最大反思补搜轮数；初学调试建议 1-2，完整演示可设 3。
MAX_ITERATIONS=2

# 是否开启记忆系统；未启动 Postgres/Redis 时建议 false。
ENABLE_MEMORY=false

# 短期记忆过期时间，单位秒；604800 等于 7 天。
SHORT_TERM_TTL_SECONDS=604800

# 短期记忆最多保留的消息数量。
SHORT_TERM_MAX_MESSAGES=30

# 会话消息超过该数量后触发摘要压缩。
SHORT_TERM_SUMMARY_THRESHOLD=20

# 短期记忆后端，可选 postgres 或 redis。
SHORT_TERM_BACKEND=postgres

# 长期记忆后端，项目主要支持 postgres，也有本地 SQLite fallback 逻辑。
LONG_TERM_BACKEND=postgres

# 长期记忆作用域；user 表示按用户维度保存。
LONG_TERM_SCOPE=user

# 是否把对话任务沉淀为长期记忆；初期建议 false。
SAVE_CONVERSATION_TASK=false

# LangGraph checkpoint 后端；最小启动用 memory，完整记忆版用 postgres。
CHECKPOINTER_BACKEND=memory

# 是否开启 Milvus 向量库/RAG；未启动 Milvus 时必须 false。
ENABLE_MILVUS=false

# 注入 prompt 的相关记忆数量。
MEMORY_TOP_K=6

# Redis 连接地址；例如 redis://:RedisPass123@127.0.0.1:6379。
REDIS_URL=

# PostgreSQL 连接串；例如 postgresql://root:RootPass123@127.0.0.1:5432/deepresearch。
POSTGRES_DSN=

# Milvus 地址；本机 Docker 启动后通常是 127.0.0.1。
MILVUS_HOST=

# Milvus gRPC 端口，默认 19530。
MILVUS_PORT=19530

# Milvus collection 名称，用于存储知识库/语义记忆向量。
MILVUS_COLLECTION=mult_agent_memory

# 终端日志是否禁用彩色输出；一般留空。
NO_COLOR=

# 工具函数允许访问的工作目录；当前主流程基本不依赖。
WORKSPACE_DIR=/workspace

